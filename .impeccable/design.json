  "narrative": {
    "northStar": "The Mint Desk",
    "overview": "Po Agent Web is a focused desk for working with an AI coding agent. The Agent Mint theme provides warm neutral light surfaces with a fresh mint-green accent for state and selection, and black primary actions for high-contrast CTA clarity. Hierarchy comes from tone, spacing, border, and subtle card elevation rather than decorative effects.",
    "keyCharacteristics": [
      "Single Agent Mint light theme with warm neutral surfaces.",
      "Mint-green accent reserved for state, selection, focus, and live agent indicators.",
      "Black primary actions for high-contrast CTA clarity.",
      "Gentle card elevation with resting shadow; floating surfaces use stronger shadows.",
      "Compact 6px, 8px, and 12px radius vocabulary.",
      "Short state-driven motion with reduced-motion support."
    ],
    "rules": [
      {
        "name": "The Mint State Rule",
        "body": "Accent color is reserved for state, selection, focus, and live agent indicators; primary actions use black. Accent text uses accent-deep to ensure WCAG AA contrast.",
        "section": "colors"
      },
      {
        "name": "The Gentle Elevation Rule",
        "body": "Cards use a subtle resting shadow. Stronger shadows appear only for genuine floating surfaces like dialogs and dropdowns.",
        "section": "elevation"
      }
    ],
    "dos": [
      "Do keep the canvas warm neutral and panels pure white.",
      "Do use mint accent for state, selection, focus, and live indicators only.",
      "Do use black for primary action buttons.",
      "Do use accent-deep for accent-colored text and links.",
      "Do rely on tone, border, and subtle shadows for hierarchy.",
      "Do keep keyboard focus visible and support reduced motion."
    ],
    "donts": [
      "Don't use chatty mascots, emoji overload, or bubbly rounded everything.",
      "Don't use gradient text, glassmorphism, or purple-blue gradients.",
      "Don't use neon accents or high-chroma gamer styling.",
      "Don't use bright accent color for text without checking WCAG AA contrast.",
      "Don't use side-stripe borders greater than 1px as a colored accent."
    ]
  }
