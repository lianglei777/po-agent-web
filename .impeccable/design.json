  "narrative": {
    "northStar": "The Focused Desk",
    "overview": "Po Agent Web is a focused desk for working with an AI coding agent. Adaptive Workbench provides cool neutral light surfaces with restrained pine focus; Deep Focus provides charcoal dark surfaces with a mint focus color. The themes share structure but are tuned independently. Hierarchy comes from tone, spacing, and border rather than decorative effects.",
    "keyCharacteristics": [
      "Adaptive Workbench light theme and Deep Focus dark theme.",
      "Neutral-first color with accent reserved for action, focus, selection, and live state.",
      "Flat-by-default elevation; shadows only for genuine floating surfaces.",
      "Compact 4px, 6px, and 8px radius vocabulary.",
      "Short state-driven motion with reduced-motion support."
    ],
    "rules": [
      {
        "name": "The Neutral First Rule",
        "body": "Accent color is reserved for primary actions, focus, selection, and live agent state; it is never decorative.",
        "section": "colors"
      },
      {
        "name": "The Tonal First Rule",
        "body": "Surfaces are flat at rest. Shadows appear only when an element genuinely floats above the content plane.",
        "section": "elevation"
      }
    ],
    "dos": [
      "Do keep the light canvas cool neutral and the dark canvas charcoal.",
      "Do use accent for primary actions, current selection, focus, and live state only.",
      "Do rely on tone and border for hierarchy before reaching for shadow.",
      "Do keep keyboard focus visible and support reduced motion."
    ],
    "donts": [
      "Don't use chatty mascots, emoji overload, or bubbly rounded everything.",
      "Don't use gradient text, glassmorphism, or purple-blue gradients.",
      "Don't use neon accents or high-chroma gamer dark mode.",
      "Don't use shadows as the default state for every container.",
      "Don't use side-stripe borders greater than 1px as a colored accent."
    ]
