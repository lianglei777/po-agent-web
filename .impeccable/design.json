  "narrative": {
    "northStar": "The Neutral Desk",
    "overview": "Po Agent is a focused desk for working with an AI coding agent. The Codex-like neutral light theme provides a white canvas, translucent gray sidebars, compact controls, neutral selection, restrained blue state accents, and dark primary actions. Hierarchy comes from tone, spacing, and border rather than decorative effects.",
    "keyCharacteristics": [
      "Single Codex-like neutral light theme with white and soft gray surfaces.",
      "Codex blue reserved for focus, links, switches, live agent indicators, and explicit status.",
      "Black primary actions for high-contrast CTA clarity.",
      "Flat resting surfaces; floating composer, dialogs, and menus use restrained shadows.",
      "Rounded controls and larger composer radii without playful decoration.",
      "Short state-driven motion with reduced-motion support."
    ],
    "rules": [
      {
        "name": "The Restrained State Rule",
        "body": "Accent color is reserved for focus, live agent indicators, and explicit status; primary actions use black. Passive selection uses neutral gray.",
        "section": "colors"
      },
      {
        "name": "The Flat Surface Rule",
        "body": "Resting cards are flat. Shadows appear only for genuine floating surfaces like composer, dialogs, and dropdowns.",
        "section": "elevation"
      }
    ],
    "dos": [
      "Do keep the canvas white and sidebars soft gray.",
      "Do use Codex blue for focus, links, switches, status, and live indicators only.",
      "Do use black for primary action buttons.",
      "Do use neutral gray for selected navigation and passive highlights.",
      "Do rely on tone, border, and spacing for hierarchy.",
      "Do keep keyboard focus visible and support reduced motion."
    ],
    "donts": [
      "Don't use chatty mascots, emoji overload, or bubbly rounded everything.",
      "Don't use gradient text, glassmorphism, or purple-blue gradients.",
      "Don't use neon accents or high-chroma gamer styling.",
      "Don't use bright accent color for text without checking WCAG AA contrast.",
      "Don't use side-stripe borders greater than 1px as a colored accent."
    ]
  }
