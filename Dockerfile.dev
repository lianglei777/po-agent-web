# syntax=docker/dockerfile:1.7

ARG NPM_REGISTRY=https://registry.npmmirror.com

FROM node:22-bookworm-slim
ARG NPM_REGISTRY
WORKDIR /app

# 只装依赖；源码通过 compose 的 volume 挂载进来，保证热更新
COPY package.json package-lock.json ./
RUN npm config set registry "${NPM_REGISTRY}" \
 && npm ci --no-audit --no-fund

ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=development
ENV PORT=51732
# next dev 的 hostname 默认就是 0.0.0.0，容器外可直接访问
ENV PI_CODING_AGENT_DIR=/data/pi-agent

EXPOSE 51732
# 直接调用 next dev 并指定 51732：package.json 的 dev 脚本里 `-p 51731` 会覆盖 PORT 环境变量，
# 故这里不走 npm run dev，而是显式用 51732 端口，与本机 dev（51731）错开。
CMD ["npx", "next", "dev", "-p", "51732"]
