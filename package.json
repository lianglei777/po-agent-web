{
  "name": "po-agent-web",
  "version": "0.1.0",
  "description": "Local desktop workspace for the Pi coding agent.",
  "author": "Po Agent Web",
  "private": true,
  "main": "desktop/main.mjs",
  "scripts": {
    "dev": "next dev -p 51731",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && node --test desktop/desktop-runtime.test.mjs desktop/prepare-standalone.test.mjs",
    "check": "npm run lint && npm run typecheck && npm test",
    "desktop:prepare": "node desktop/prepare-standalone.mjs",
    "desktop:dev": "npm run build && npm run desktop:prepare && electron .",
    "desktop:pack": "npm run build && npm run desktop:prepare && electron-builder --dir --publish never",
    "desktop:dist": "npm run build && npm run desktop:prepare && electron-builder --publish never"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@types/react-syntax-highlighter": "^15.5.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.42.2",
    "next": "16.2.1",
    "radix-ui": "^1.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.poagent.web",
    "productName": "Po Agent Web",
    "icon": "build/icon.png",
    "directories": {
      "output": ".desktop-dist"
    },
    "files": [
      "desktop/**/*",
      "build/icon.png",
      "package.json",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "server",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "server/.next/static"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
